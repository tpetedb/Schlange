# Schlange -- Full Pipeline Configuration
# Copy to .env and fill in your values

# --- Spotify API (required for Tom 2000 playlist) ---
SPOTIPY_CLIENT_ID=your_client_id_here
SPOTIPY_CLIENT_SECRET=your_client_secret_here
SPOTIPY_REDIRECT_URI=http://127.0.0.1:8888/callback

# --- Video pipeline ---
# VIDEO_BACKEND=placeholder
# VIDEO_API_KEY=your_api_key

# --- Event details ---
GOODBYE_DATE=2026-03-12
GOODBYE_LOCATION= head quarters, Breda, Netherlands

# --- Email sending ---
# EMAIL_FROM=smutzige.hansi@example.com
# SMTP_HOST=smtp.example.com
# SMTP_USER=your_smtp_user
# SMTP_PASS=your_smtp_password
# RECIPIENTS=alice@example.com,bob@example.com

# --- Links (used in email) ---
SPOTIFY_PLAYLIST_URL=https://open.spotify.com/playlist/0zlnNw3Jo0084x2AFgtuxU
# GITHUB_REPO_URL=https://github.com/tpetedb/Schlange
# TOM_WEBSITE_URL=https://example.com
